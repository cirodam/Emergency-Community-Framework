{
  "name": "emergency-community-framework",
  "private": true,
  "scripts": {
    "build": "npm run build -w @ecf/core && npm run build -w @ecf/bank && npm run build -w @ecf/community && npm run build -w @ecf/federation",
    "docker:build:bank": "docker build -f packages/bank/Dockerfile -t ecf-bank .",
    "docker:build:community": "docker build -f packages/community/Dockerfile -t ecf-community .",
    "docker:build:federation": "docker build -f packages/federation/Dockerfile -t ecf-federation .",
    "docker:build": "npm run docker:build:bank && npm run docker:build:community && npm run docker:build:federation",
    "docker:up:community": "docker compose -f docker-compose.community.yml up",
    "docker:up:federation": "docker compose -f docker-compose.federation.yml up",
    "docker:down:community": "docker compose -f docker-compose.community.yml down",
    "docker:down:federation": "docker compose -f docker-compose.federation.yml down"
  },
  "workspaces": [
    "packages/core",
    "packages/bank",
    "packages/community",
    "packages/federation"
  ]
}
